generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Link {
  id          String   @id @default(cuid())
  slug        String   @unique
  originalUrl String
  createdAt   DateTime @default(now())

  clicks Click[]
}

model Click {
  id        String   @id @default(cuid())
  linkId    String
  clickedAt DateTime @default(now())
  userAgent String?
  referrer  String?

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([clickedAt])
}